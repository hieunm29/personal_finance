{
  "name": "@pf/server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "echo 'Server runs with Bun, no build step'",
    "db:seed": "bun run src/db/seed.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "@pf/shared": "workspace:*",
    "better-auth": "^1.4.20",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.6.20",
    "jose": "^6.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.7.3"
  }
}
